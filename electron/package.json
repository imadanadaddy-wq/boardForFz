{
  "name": "maple-overlay-electron",
  "version": "1.0.0",
  "description": "Hyeong Maple Overlay — 게임 위 항상 고정 데스크톱 오버레이",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.hyeong.maple-overlay",
    "productName": "Maple Overlay",
    "directories": { "output": "../dist-electron" },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "Hyeong",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}
